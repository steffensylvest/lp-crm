# ── LP CRM · Database connection ──────────────────────────────────────────────
#
# Copy this file to .env and fill in the right values for your environment.
# The app reads DATABASE_URL on startup — changing it is the only step needed
# to switch backends.
#
# ── Option 1: SQLite (default, zero setup) ────────────────────────────────────
DATABASE_URL=sqlite:///./lp_crm.db

# ── Option 2: PostgreSQL (optional intermediate) ──────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/lp_crm

# ── Option 3: Snowflake ───────────────────────────────────────────────────────
# Replace every placeholder value (ALL_CAPS) with your real credentials.
# Requires: pip install snowflake-sqlalchemy snowflake-connector-python
#
# DATABASE_URL=snowflake://SF_USER:SF_PASSWORD@SF_ACCOUNT/SF_DATABASE/SF_SCHEMA?warehouse=SF_WAREHOUSE&role=SF_ROLE
#
# SF_ACCOUNT   → your Snowflake account identifier, e.g. abc12345.eu-west-1
# SF_DATABASE  → the Snowflake database, e.g. LP_CRM_DB
# SF_SCHEMA    → the schema inside that database, e.g. PUBLIC
# SF_WAREHOUSE → compute warehouse name, e.g. COMPUTE_WH
# SF_ROLE      → role with USAGE + table privileges, e.g. LP_CRM_ROLE
